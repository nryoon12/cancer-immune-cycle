                  RowBox[{"1", "/", "#"}], ",", "T"}], "]"}]}], "]"}], 
              "\[Equal]", "0"}], ",", "T"}], "]"}]}], "]"}], "&"}], "/@", 
        "\[Lambda]R1"}], ")"}], "/.", 
