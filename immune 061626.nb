          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"1", "/", "#"}], ",", "T"}], "]"}], "\[Equal]", "0"}], 
          ",", "T"}], "]"}], "\[LeftDoubleBracket]", "1", 
