Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Tbp", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"T", "/.", 
       RowBox[{
        RowBox[{"Solve", "[", 
