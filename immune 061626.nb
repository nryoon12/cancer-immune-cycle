Cell[BoxData[
 RowBox[{
  RowBox[{"spsink", "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f", "=", 
       RowBox[{"{", " ", 
        RowBox[{
         FractionBox[
          RowBox[{"Sin", "[", "x", "]"}], 
          SuperscriptBox["x", "2"]], ",", 
         FractionBox[
          RowBox[{"Cos", "[", "x", "]"}], 
          SuperscriptBox["x", "2"]]}], "}"}]}], "}"}], ",", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"ParametricPlot", "[", 
        RowBox[{
         RowBox[{"f", "/.", 
          RowBox[{"x", "->", "t"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "8", ",", "25"}], "}"}], ",", 
         RowBox[{"PlotStyle", "->", "Black"}], ",", 
         RowBox[{"Axes", "->", "False"}], ",", 
         RowBox[{"Epilog", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"PointSize", "[", ".04", "]"}], ",", 
            RowBox[{"Point", "[", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}], "}"}], "]"}]}], "}"}]}]}], 
        "]"}], ",", 
       RowBox[{"Graphics", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"Hue", "[", 
               RowBox[{
                RowBox[{"t", "/", 
                 RowBox[{"(", 
                  RowBox[{"2", " ", "Pi"}], ")"}]}], ",", "1", ",", ".8"}], 
               "]"}], ","}], "*)"}], 
            RowBox[{
             RowBox[{"Arrowheads", "[", ".06", "]"}], ",", 
             RowBox[{"Arrow", "[", 
              RowBox[{"{", 
               RowBox[{"f", ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Normalize", "[", 
                   RowBox[{"D", "[", 
                    RowBox[{"f", ",", "x"}], "]"}], "]"}], "/", "1000"}], "+",
                  "f"}]}], "}"}], "]"}]}], "}"}], "/.", " ", 
           RowBox[{"x", "->", "t"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "8", ",", "25", ",", "2"}], "}"}]}], "]"}], 
        "]"}]}], "]"}]}], "]"}]}], ";"}]], "Input",
